sys_password: "CHANGE_ME"
dbca_sys_password: "CHANGE_ME"
dbca_system_password: "CHANGE_ME"
dbca_db_snmp_password: "CHANGE_ME"
dbca_pdb_admin_password: "CHANGE_ME"

